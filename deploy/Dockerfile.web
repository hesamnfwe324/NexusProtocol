FROM node:20-alpine AS builder
WORKDIR /app

RUN npm install -g pnpm@10

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY lib/ ./lib/
COPY artifacts/airdrop/ ./artifacts/airdrop/
COPY attached_assets/ ./attached_assets/

# Disable minimumReleaseAge so pnpm install works on build servers
RUN sed -i 's/minimumReleaseAge: 1440/minimumReleaseAge: 0/' pnpm-workspace.yaml

RUN pnpm install --no-frozen-lockfile

ENV PORT=3000
ENV BASE_PATH=/airdrop/
ENV NODE_ENV=production

RUN pnpm --filter @workspace/airdrop run build

# ── Nginx runtime ──
FROM nginx:1.27-alpine
COPY --from=builder /app/artifacts/airdrop/dist/public /usr/share/nginx/html/airdrop
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
